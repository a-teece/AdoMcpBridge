{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AdoMcp": {
    "Issuer": "https://localhost:5001",
    "UpstreamBaseUrl": "https://mcp.dev.azure.com"
  },
  "ReverseProxy": {
    "Routes": {
      "mcp": {
        "ClusterId": "ado-mcp",
        "Match": { "Path": "/mcp/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "ado-mcp": {
        "Destinations": {
          "primary": { "Address": "https://mcp.dev.azure.com/" }
        }
      }
    }
  }
}
